# Docker Build Optimization
# Copied from Railway default .dockerignore to optimize build times

# Git
.git
.gitignore

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/
test-results/
playwright-report/

# Development
.env.local
.env.*.local
.env.development

# IDE
.vscode/
.idea/
*.swp
*.swo
.vim/
.DS_Store

# Build artifacts
.next/
dist/
build/
out/

# OS
Thumbs.db
.DS_Store

# Temporary
.tmp/
.cache/
tmp/
*.tmp

# Documentation
docs/
README.md
CHANGELOG.md

# Examples & Templates
examples/
*.example

# CI/CD
.github/
.gitlab-ci.yml
.circleci/

# Misc
*.log
.turbo/
.pnp
.pnp.js

# Database local files (only for development)
*.db
*.sqlite
*.sqlite3
prisma/dev.db

# Lock files (optional - uncomment if using Docker layer caching)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
