# Database URL
# Local development (SQLite — default):
DATABASE_URL="file:./dev.db"
# Production / PostgreSQL (set this in your hosting platform's environment variables):
# DATABASE_URL="postgresql://user:password@host:5432/card_benefits"

# Authentication & Session Management
# CRITICAL: Generate a random 256-bit (32-byte) key for SESSION_SECRET
# Commands to generate:
#   openssl rand -hex 32          # Linux/Mac
#   [System.Convert]::ToBase64String([byte[]]32 | % {[Math]::Random() * 256 -as [byte]})  # Windows
# Store in .env.local (never commit to version control)
SESSION_SECRET=""

# Cron Job Security
# CRITICAL: Generate a random secret for cron jobs
# This prevents unauthorized access to the /api/cron/reset-benefits endpoint
# Use a different value than SESSION_SECRET
CRON_SECRET=""

# Environment
NODE_ENV=development

# Benefit Engine Feature Flag
# Controls whether the new period-based benefit engine is active.
# When false (default): legacy flat benefit creation (no period tracking)
# When true: auto-generation engine with period start/end, cadence math, history
# Deploy with false initially; flip to true after verifying data backfill.
BENEFIT_ENGINE_ENABLED=false
