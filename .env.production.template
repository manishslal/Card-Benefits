# Railway Production Environment Variables Template
# Copy this to .env in Railway dashboard, filling in actual values
# NEVER commit this file with real values!

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Railway automatically provides this when PostgreSQL plugin is added
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://user:password@host:5432/card-benefits

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Generate with: openssl rand -hex 32
# 256-bit random hex string (64 characters)
SESSION_SECRET=<generate-with-openssl-rand-hex-32>

# Generate with: openssl rand -hex 32
# Used to authenticate cron job requests
CRON_SECRET=<generate-with-openssl-rand-hex-32>

# ============================================
# RUNTIME CONFIGURATION
# ============================================
# Set automatically by Railway, but explicit for clarity
NODE_ENV=production

# Optional: Control logging verbosity
# Values: error, warn, info, debug
LOG_LEVEL=info

# Optional: For distributed tracing/correlation IDs
# TRACE_ID_HEADER=x-trace-id

# ============================================
# FEATURE FLAGS & CONFIGURATION
# ============================================
# Optional: Redis URL for distributed rate limiting
# Format: redis://[user]:[password]@[host]:[port]
# Only needed if implementing Redis-backed rate limiting
# REDIS_URL=redis://host:6379

# ============================================
# ERROR TRACKING (Optional but recommended)
# ============================================
# Sentry DSN for error aggregation
# Get from: https://sentry.io/organizations/YOUR-ORG/projects/
# SENTRY_DSN=https://[key]@sentry.io/[project-id]

# ============================================
# THIRD-PARTY INTEGRATIONS (Optional)
# ============================================
# NewRelic, DataDog, or other APM
# NEW_RELIC_LICENSE_KEY=<your-key-here>
# DATADOG_API_KEY=<your-key-here>

# ============================================
# NEXT.JS SPECIFIC (Auto-handled by Railway)
# ============================================
# Next.js automatically detects in production
# NEXT_PUBLIC_API_URL=https://your-app.railway.app

# ============================================
# SECURITY HEADERS & CORS (Optional)
# ============================================
# ALLOWED_ORIGINS=https://your-app.railway.app
# CSP_POLICY=default-src 'self'

# ============================================
# NOTES
# ============================================
# 1. Replace all <...> placeholders with actual values
# 2. Never commit this file with real secrets
# 3. Use Railway's Environment Variables page to set these
# 4. Railway will provide DATABASE_URL automatically
# 5. Rotate SESSION_SECRET and CRON_SECRET regularly
# 6. Test each variable after deployment
