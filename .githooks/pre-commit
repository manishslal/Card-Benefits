#!/bin/bash

# Pre-commit hook: Prevent committing .env files with production credentials

echo "🔐 Pre-commit check: Validating files..."

# Check if .env is being staged (but allow .env.example)
if git diff --cached --name-only | grep -q "^\.env$\|^\.env\.local$\|^\.env\.production$"; then
    echo "⚠️  WARNING: You're about to commit .env file!"
    echo ""
    echo "DANGER: .env contains DATABASE_URL and other secrets"
    echo ""
    echo "✋ BLOCKED - .env files should NEVER be committed"
    echo ""
    echo "If you need to commit environment config:"
    echo "  1. Use .env.local (added to .gitignore)"
    echo "  2. Use .env.example with DUMMY values"
    echo "  3. Use Railway dashboard for secrets"
    echo ""
    exit 1
fi

# Check if someone is trying to update .env.example with real secrets
if git diff --cached .env.example | grep -q "junction.proxy.rlwy.net"; then
    echo "⚠️  DANGER: Real production credentials in .env.example!"
    echo ""
    echo ".env.example should contain DUMMY values only"
    echo "Real credentials belong in .env or Railway secrets"
    echo ""
    exit 1
fi

echo "✅ Pre-commit checks passed"
exit 0
