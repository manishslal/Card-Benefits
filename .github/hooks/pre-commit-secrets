#!/bin/bash
# Pre-commit hook to prevent committing .env files
# Install: cp .github/hooks/pre-commit-secrets .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

# Check for .env files being committed
echo "🔒 Checking for .env files..."

# Files that should never be committed
FORBIDDEN_PATTERNS=(
    "\.env$"
    "\.env\.local$"
    "\.env\..+\.local$"
)

# Get list of files being committed
STAGED_FILES=$(git diff --cached --name-only)

# Check each staged file against forbidden patterns
FOUND_VIOLATION=0
for file in $STAGED_FILES; do
    for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
        if [[ "$file" =~ $pattern ]]; then
            echo "❌ ERROR: Cannot commit '$file' - contains secrets"
            FOUND_VIOLATION=1
        fi
    done
done

if [ $FOUND_VIOLATION -eq 1 ]; then
    echo ""
    echo "🚫 Commit aborted: Environment files detected"
    echo ""
    echo "To fix:"
    echo "  1. Remove .env files from staging: git reset HEAD .env"
    echo "  2. Ensure .env is in .gitignore: grep '.env' .gitignore"
    echo "  3. Try committing again"
    echo ""
    exit 1
fi

# Also check for common secrets in staged content
echo "🔐 Scanning for hardcoded secrets..."

SECRETS_PATTERNS=(
    "SESSION_SECRET\s*=\s*['\"]?[a-f0-9]{64}['\"]?"
    "CRON_SECRET\s*=\s*['\"]?[a-f0-9]{64}['\"]?"
    "DATABASE_URL\s*=\s*postgresql://.*@.*:.*"
    "password\s*[:=]\s*['\"][^'\"]*['\"]"
    "api[_-]?key\s*[:=]\s*['\"][^'\"]*['\"]"
)

FOUND_SECRET=0
for pattern in "${SECRETS_PATTERNS[@]}"; do
    if git diff --cached | grep -iE "$pattern" > /dev/null; then
        echo "⚠️  WARNING: Possible hardcoded secret detected (pattern: $pattern)"
        echo "    Are you sure you want to commit this?"
        echo ""
        read -p "    Continue? (y/N): " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "❌ Commit aborted by user"
            exit 1
        fi
    fi
done

echo "✅ Pre-commit checks passed"
exit 0
