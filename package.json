{
  "name": "card-benefits-tracker",
  "version": "1.0.0",
  "description": "A comprehensive Credit Card Benefits Tracker built with Next.js, TypeScript, and Prisma",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "node scripts/repair-migrations.js && prisma migrate deploy && next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "prisma:migrate": "node scripts/validate-db-connection.js && prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node --require ts-node/register prisma/seed.ts",
    "db:push": "node scripts/validate-db-connection.js && prisma db push",
    "db:reset": "node scripts/validate-db-connection.js && prisma db push --force-reset && npm run prisma:seed",
    "db:generate": "prisma generate",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "focus-trap-react": "^12.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "next": "^15.0.0",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.1.2",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.2",
    "postcss": "^8.5.8",
    "prisma": "^5.8.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
