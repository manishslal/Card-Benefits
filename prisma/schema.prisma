generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MasterCard {
  id               String          @id @default(cuid())
  issuer           String
  cardName         String
  defaultAnnualFee Int
  cardImageUrl     String
  
  // Display properties (NEW)
  displayOrder     Int             @default(0)
  isActive         Boolean         @default(true)
  isArchived       Boolean         @default(false)
  
  // Audit fields (NEW)
  createdByAdminId String?
  archivedByAdminId String?
  archivedAt       DateTime?
  archivedReason   String?
  
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  masterBenefits   MasterBenefit[]
  userCards        UserCard[]
  cardLoungeAccess CardLoungeAccess[]

  @@unique([issuer, cardName])
  @@index([issuer])
  @@index([cardName])
  @@index([displayOrder])
  @@index([isActive])
  @@index([isArchived])
}

model MasterBenefit {
  id              String          @id @default(cuid())
  masterCardId    String
  
  name            String
  type            String
  stickerValue    Int
  resetCadence    String
  
  // Default behavior (NEW)
  /// When true, this benefit is automatically created for new UserCards via
  /// generateBenefitsForCard().  When false, the benefit exists in the catalog
  /// but users must manually opt in to track it (e.g., welcome bonuses that
  /// depend on meeting a minimum-spend requirement).
  isDefault       Boolean         @default(true)
  isActive        Boolean         @default(true)
  
  // Phase 6C: Claiming Cadence Fields (NEW)
  // claimingCadence: MONTHLY | QUARTERLY | SEMI_ANNUAL | FLEXIBLE_ANNUAL | ONE_TIME
  // claimingAmount: Amount per period in cents (e.g., 1500 = $15)
  // claimingWindowEnd: For custom windows like "0918" for Amex Sept 18 split
  claimingCadence String?
  claimingAmount  Int?
  claimingWindowEnd String?
  variableAmounts Json?    // e.g., { "12": 3500 } → December = $35.00 in cents
  
  // Audit fields (NEW)
  createdByAdminId String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  masterCard      MasterCard      @relation(fields: [masterCardId], references: [id], onDelete: Cascade)

  // ─── NEW: Reverse relation to UserBenefit (Benefit Engine) ────────
  userBenefits    UserBenefit[]

  @@index([masterCardId])
  @@index([type])
  @@index([resetCadence])
  @@index([claimingCadence])
  @@index([isDefault])
  @@index([isActive])
}

model User {
  id             String              @id @default(cuid())
  email          String              @unique
  passwordHash   String
  firstName      String?
  lastName       String?
  emailVerified  Boolean             @default(false)

  // Admin fields (NEW)
  role           UserRole            @default(USER)
  isActive       Boolean             @default(true)

  // Password Reset Fields
  passwordResetToken  String?  @unique @db.VarChar(255)
  passwordResetExpiry DateTime?

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  importJobs     ImportJob[]
  players        Player[]
  sessions       Session[]
  importProfiles UserImportProfile[]
  auditLogs      AdminAuditLog[]     // Admin who performed actions

  // Phase 2A - Benefit periods, recommendations, and usage tracking
  benefitPeriods    BenefitPeriod[]
  recommendations   BenefitRecommendation[]
  usageRecords      BenefitUsageRecord[]
  benefitEvents     BenefitEvent[]

  // Phase 2B - Onboarding sessions
  onboardingSessions OnboardingSession[] @relation("UserOnboardingSessions")

  @@index([email])
  @@index([role])
  @@index([isActive])
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expiresAt    DateTime
  isValid      Boolean  @default(true)
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Player {
  id           String        @id @default(cuid())
  userId       String
  playerName   String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  importJobs   ImportJob[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userBenefits UserBenefit[]
  userCards    UserCard[]
  onboardingSession OnboardingSession?

  @@unique([userId, playerName])
  @@index([userId])
}

model UserCard {
  id                  String        @id @default(cuid())
  playerId            String
  masterCardId        String
  customName          String?
  actualAnnualFee     Int?
  renewalDate         DateTime
  isOpen              Boolean       @default(true)
  status              String        @default("ACTIVE")
  statusChangedAt     DateTime?
  statusChangedReason String?
  statusChangedBy     String?
  archivedAt          DateTime?
  archivedBy          String?
  archivedReason      String?
  importedFrom        String?
  importedAt          DateTime?
  version             Int           @default(1)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  userBenefits        UserBenefit[]
  benefitEvents       BenefitEvent[]
  masterCard          MasterCard    @relation(fields: [masterCardId], references: [id], onDelete: Cascade)
  player              Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, masterCardId])
  @@index([playerId])
  @@index([masterCardId])
  @@index([playerId, masterCardId])
  @@index([playerId, status])
  @@index([renewalDate])
  @@index([archivedAt])
}

model UserBenefit {
  id                String    @id @default(cuid())
  userCardId        String
  playerId          String

  // ─── NEW: Foreign key to MasterBenefit catalog ───────────────────
  // Nullable to support custom user-created benefits (no master template)
  masterBenefitId   String?

  // ─── PRESERVED: Denormalized display fields (kept for custom benefits & perf) ───
  name              String
  type              String
  stickerValue      Int
  resetCadence      String

  // ─── NEW: Period tracking fields ──────────────────────────────────
  // Each UserBenefit row represents ONE period. periodStart + periodEnd
  // define the window this benefit instance covers.
  periodStart       DateTime?   // Start of this benefit period (UTC)
  periodEnd         DateTime?   // End of this benefit period (UTC)
  periodStatus      String      @default("ACTIVE")
  // Enum-like values: "ACTIVE" | "EXPIRED" | "UPCOMING"

  // ─── PRESERVED: Usage tracking ────────────────────────────────────
  userDeclaredValue Int?
  isUsed            Boolean   @default(false)
  timesUsed         Int       @default(0)
  claimedAt         DateTime?

  // ─── DEPRECATED but PRESERVED for backward compat ─────────────────
  // expirationDate is superseded by periodEnd but kept during migration
  expirationDate    DateTime?

  // ─── PRESERVED: Metadata ──────────────────────────────────────────
  status            String    @default("ACTIVE")
  importedFrom      String?
  importedAt        DateTime?
  version           Int       @default(1)
  valueHistory      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // ─── Relations ────────────────────────────────────────────────────
  masterBenefit     MasterBenefit? @relation(fields: [masterBenefitId], references: [id], onDelete: SetNull)
  player            Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  userCard          UserCard  @relation(fields: [userCardId], references: [id], onDelete: Cascade)

  // Phase 2A relations (preserved)
  usagePeriods      BenefitPeriod[]
  recommendations   BenefitRecommendation[]
  usageRecords      BenefitUsageRecord[]
  benefitEvents     BenefitEvent[]
  trackerProjection BenefitTrackerProjection?

  // ─── Unique constraints ───────────────────────────────────────────
  // Includes periodStart so multiple period rows can coexist for the same benefit
  // (e.g., April + May rows for "$10 Dining Credit"). Legacy rows with
  // periodStart=NULL are naturally unique under PostgreSQL NULL semantics.
  @@unique([userCardId, name, periodStart])

  // ─── Indexes ──────────────────────────────────────────────────────
  @@index([userCardId])
  @@index([playerId])
  @@index([userCardId, name])
  @@index([type])
  @@index([isUsed])
  @@index([expirationDate])
  // NEW: Benefit engine performance indexes
  @@index([masterBenefitId])
  @@index([periodStatus])
  @@index([periodEnd, periodStatus])
  @@index([userCardId, masterBenefitId, periodStart])
}

model ImportJob {
  id                  String         @id @default(cuid())
  playerId            String
  userId              String
  fileName            String
  fileFormat          String
  fileSize            Int
  fileHash            String?
  status              String         @default("Uploaded")
  totalRecords        Int
  processedRecords    Int            @default(0)
  skippedRecords      Int            @default(0)
  failedRecords       Int            @default(0)
  warningRecords      Int            @default(0)
  importType          String
  cardsCreated        Int            @default(0)
  cardsUpdated        Int            @default(0)
  benefitsCreated     Int            @default(0)
  benefitsUpdated     Int            @default(0)
  errorLog            String?
  previewData         String?
  conflictLog         String?
  columnMappings      String?
  detectionConfidence Float?         @default(1.0)
  createdAt           DateTime       @default(now())
  uploadedAt          DateTime?
  parsedAt            DateTime?
  validatedAt         DateTime?
  committedAt         DateTime?
  completedAt         DateTime?
  player              Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  records             ImportRecord[]

  @@index([playerId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([playerId, createdAt])
}

model ImportRecord {
  id                 String    @id @default(cuid())
  importJobId        String
  recordType         String
  rowNumber          Int
  sequenceIndex      Int
  data               String
  normalizedData     String?
  status             String    @default("Valid")
  validationErrors   String?
  validationWarnings String?
  isDuplicate        Boolean   @default(false)
  duplicateOf        String?
  userResolution     String?
  createdCardId      String?
  createdBenefitId   String?
  updatedCardId      String?
  updatedBenefitId   String?
  appliedData        String?
  processedAt        DateTime?
  appliedAt          DateTime?
  importJob          ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@index([status])
  @@index([rowNumber])
  @@index([isDuplicate])
}

model UserImportProfile {
  id                String    @id @default(cuid())
  userId            String
  name              String
  description       String?
  fileFormat        String
  columnMappings    String
  mappingConfidence Float     @default(1.0)
  usageCount        Int       @default(0)
  lastUsedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastUsedAt])
}

// ============================================================================
// ADMIN AUDIT LOGGING - NEW (Phase 1)
// ============================================================================

model AdminAuditLog {
  id              String          @id @default(cuid())
  
  // Who performed the action
  adminUserId     String
  adminUser       User            @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  
  // What was changed
  actionType      AuditActionType // CREATE, UPDATE, DELETE
  resourceType    ResourceType    // CARD, BENEFIT, USER_ROLE, etc.
  resourceId      String
  resourceName    String?
  
  // Change details
  oldValues       String?         // JSON string of previous values
  newValues       String?         // JSON string of new values
  
  // Request context
  ipAddress       String?
  userAgent       String?
  
  // Timestamp
  timestamp       DateTime        @default(now())
  
  @@index([adminUserId])
  @@index([actionType])
  @@index([resourceType])
  @@index([resourceId])
  @@index([timestamp])
  @@index([adminUserId, timestamp])
}

enum AuditActionType {
  CREATE
  UPDATE
  DELETE
}

enum ResourceType {
  CARD
  BENEFIT
  USER_ROLE
  SYSTEM_SETTING
}

enum BenefitEventFamily {
  UNLIMITED_USE
  MULTIPLIER_SPEND
}

enum BenefitEventType {
  USAGE_ADD
  USAGE_REMOVE
  SPEND_ADD
  SPEND_REMOVE
  POINTS_ADD
  POINTS_REMOVE
  ADJUSTMENT
}

// ============================================================================
// PHASE 2A - USAGE TRACKING, BENEFIT PERIODS, AND RECOMMENDATIONS
// ============================================================================

model BenefitEvent {
  id             String             @id @default(cuid())
  userId         String
  userCardId     String
  userBenefitId  String
  eventFamily    BenefitEventFamily
  eventType      BenefitEventType
  amountCents    Int?
  points         Int?
  quantity       Int?
  eventDate      DateTime
  endpointScope  String
  idempotencyKey String?
  source         String?
  notes          String?
  metadata       Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userCard   UserCard   @relation(fields: [userCardId], references: [id], onDelete: Cascade)
  userBenefit UserBenefit @relation(fields: [userBenefitId], references: [id], onDelete: Cascade)

  @@index([userBenefitId, eventDate(sort: Desc)])
  @@index([userId, eventDate(sort: Desc)])
  @@index([eventFamily, eventType, eventDate])
  @@unique([userId, endpointScope, idempotencyKey], map: "uniq_event_idempotency_scope")
}

model BenefitTrackerProjection {
  userBenefitId      String   @id
  periodStart        DateTime
  periodEnd          DateTime
  unlimitedNetCount  Int      @default(0)
  spendCentsTotal    Int      @default(0)
  pointsTotal        Int      @default(0)
  lastEventAt        DateTime?
  version            Int      @default(0)
  updatedAt          DateTime @updatedAt

  userBenefit UserBenefit @relation(fields: [userBenefitId], references: [id], onDelete: Cascade)

  @@index([periodStart, periodEnd])
}

// ============================================================================
// Model 1: BenefitUsageRecord
// Purpose: Track individual benefit usage events
// ============================================================================
model BenefitUsageRecord {
  id              String      @id @default(cuid())
  userId          String      @map("userId")
  benefitId       String      @map("benefitId")
  benefitPeriodId String?     @map("benefitPeriodId")
  usageAmount     Decimal     @db.Decimal(10, 2)  // $ or count
  usageDate       DateTime    @default(now())
  notes           String?
  category        String?     // e.g., "dining", "travel"
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relationships
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userBenefit     UserBenefit @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  benefitPeriod   BenefitPeriod? @relation(fields: [benefitPeriodId], references: [id])

  // Indexes for performance
  @@index([userId])
  @@index([benefitId])
  @@index([usageDate])
  @@index([userId, benefitId])
  // QA-007: Prevent duplicate usage records on same date
  @@unique([benefitId, userId, usageDate])
}

// ============================================================================
// Model 2: BenefitPeriod
// Purpose: Track individual benefit periods and calculate progress
// ============================================================================
model BenefitPeriod {
  id              String      @id @default(cuid())
  benefitId       String
  userId          String
  userBenefit     UserBenefit @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  periodStart     DateTime
  periodEnd       DateTime
  periodType      String      // "monthly", "quarterly", "annual", "cardmember_year"
  resetCadence    String      // Copy from UserBenefit.resetCadence

  // Aggregated values (updated by cron/trigger)
  totalUsed       Decimal     @default(0) @db.Decimal(10, 2)
  usageCount      Int         @default(0)
  usageStatus     String      @default("active") // "active", "expired", "used"

  // Tracking
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relationships
  usageRecords    BenefitUsageRecord[]

  // Indexes
  @@index([userId])
  @@index([benefitId])
  @@index([periodStart])
  @@index([periodEnd])
  @@unique([benefitId, userId, periodStart, periodEnd]) // Prevent duplicate periods
}

// ============================================================================
// Model 3: BenefitRecommendation
// Purpose: Store personalized benefit recommendations
// ============================================================================
model BenefitRecommendation {
  id              String      @id @default(cuid())
  userId          String
  benefitId       String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  benefit         UserBenefit @relation(fields: [benefitId], references: [id], onDelete: Cascade)

  score           Float       // 0.0 to 1.0 (matching score)
  reason          String      // Why recommended (for display)
  matchedCriteria String?     // JSON: which criteria matched

  dismissedAt     DateTime?   // NULL = not dismissed
  dismissReason   String?     // Why user dismissed

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Indexes
  @@index([userId])
  @@index([benefitId])
  @@index([score])
  @@index([userId, dismissedAt]) // Find active recommendations for user
}

// ============================================================================
// PHASE 2B - ONBOARDING
// ============================================================================

model OnboardingSession {
  id              String    @id @default(cuid())
  playerId        String    @unique
  userId          String
  user            User      @relation("UserOnboardingSessions", fields: [userId], references: [id], onDelete: Cascade)
  
  // Progress tracking
  currentStep     Int       @default(1) // 1-6
  completedSteps  Int       @default(0)
  isCompleted     Boolean   @default(false)
  
  // Session state (JSON blob for flexibility)
  sessionData     String?   // JSON: { selections, preferences, etc }
  
  // Tracking
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  lastStepAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  player          Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  steps           OnboardingStep[]
  
  @@index([playerId])
  @@index([isCompleted])
  @@index([createdAt])
}

model OnboardingStep {
  id              String    @id @default(cuid())
  sessionId       String
  stepNumber      Int       // 1-6
  
  // Step completion
  isCompleted     Boolean   @default(false)
  completedAt     DateTime?
  duration        Int?      // seconds spent on this step
  
  // Step data (JSON for flexibility)
  stepData        String?   // JSON: { selections, answers, preferences }
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  session         OnboardingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@unique([sessionId, stepNumber])
  @@index([sessionId])
  @@index([stepNumber])
}

// ============================================================================
// LOUNGE MODULE - Phase 1 ("The Great Addition")
// ============================================================================

model LoungeAirport {
  id        String   @id @default(cuid())
  iataCode  String   @unique @map("iata_code") @db.VarChar(3)
  name      String
  city      String
  timezone  String
  createdAt DateTime @default(now()) @map("created_at")

  terminals LoungeTerminal[]

  @@map("lounge_airports")
}

model LoungeTerminal {
  id        String   @id @default(cuid())
  airportId String   @map("airport_id")
  name      String
  isAirside Boolean  @default(true) @map("is_airside")
  createdAt DateTime @default(now()) @map("created_at")

  airport  LoungeAirport @relation(fields: [airportId], references: [id], onDelete: Cascade)
  lounges  Lounge[]

  @@index([airportId])
  @@map("lounge_terminals")
}

model Lounge {
  id                 String    @id @default(cuid())
  terminalId         String    @map("terminal_id")
  name               String
  operator           String?
  locationDetails    String?   @map("location_details")
  operatingHours     Json?     @map("operating_hours")
  amenities          Json?
  isRestaurantCredit Boolean   @default(false) @map("is_restaurant_credit")
  mayDenyEntry       Boolean   @default(false) @map("may_deny_entry")
  sourceUrl          String?   @map("source_url")
  imageUrl           String?   @map("image_url")
  venueType          String    @default("lounge") @map("venue_type")
  isAirside          Boolean?  @map("is_airside")
  gateProximity      String?   @map("gate_proximity")
  accessConditions   Json?     @map("access_conditions")
  detailLastFetchedAt DateTime? @map("detail_last_fetched_at")
  lastVerifiedAt     DateTime? @map("last_verified_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  terminal    LoungeTerminal     @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  accessRules LoungeAccessRule[]

  @@index([terminalId])
  @@index([operator])
  @@map("lounges")
}

model LoungeAccessMethod {
  id              String   @id @default(cuid())
  name            String
  category        String
  provider        String?
  grantsNetworkId String?  @map("grants_network_id")
  createdAt       DateTime @default(now()) @map("created_at")

  grantsNetwork    LoungeAccessMethod?  @relation("NetworkGrant", fields: [grantsNetworkId], references: [id])
  grantedByMethods LoungeAccessMethod[] @relation("NetworkGrant")
  accessRules      LoungeAccessRule[]
  cardAccess       CardLoungeAccess[]

  @@index([category])
  @@index([grantsNetworkId])
  @@map("lounge_access_methods")
}

model LoungeAccessRule {
  id              String    @id @default(cuid())
  loungeId        String    @map("lounge_id")
  accessMethodId  String    @map("access_method_id")
  guestLimit      Int?      @map("guest_limit")
  guestFee        Decimal?  @map("guest_fee") @db.Decimal(10, 2)
  guestConditions String?   @map("guest_conditions")
  entryCost       Decimal?  @map("entry_cost") @db.Decimal(10, 2)
  timeLimitHours  Int?      @map("time_limit_hours")
  conditions      Json?
  notes           String?
  lastVerifiedAt  DateTime? @map("last_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  lounge       Lounge             @relation(fields: [loungeId], references: [id], onDelete: Cascade)
  accessMethod LoungeAccessMethod @relation(fields: [accessMethodId], references: [id], onDelete: Cascade)

  @@unique([loungeId, accessMethodId])
  @@index([loungeId])
  @@index([accessMethodId])
  @@map("lounge_access_rules")
}

model CardLoungeAccess {
  id             String   @id @default(cuid())
  cardId         String   @map("card_id")
  accessMethodId String   @map("access_method_id")
  createdAt      DateTime @default(now()) @map("created_at")

  card         MasterCard         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  accessMethod LoungeAccessMethod @relation(fields: [accessMethodId], references: [id], onDelete: Cascade)

  @@unique([cardId, accessMethodId])
  @@index([cardId])
  @@index([accessMethodId])
  @@map("card_lounge_access")
}

model LoungeScrapeRun {
  id              String    @id @default(cuid())
  sourceName      String    @map("source_name")
  startedAt       DateTime  @map("started_at")
  completedAt     DateTime? @map("completed_at")
  recordsFound    Int?      @map("records_found")
  recordsUpserted Int?      @map("records_upserted")
  errors          Json?
  status          String

  @@map("lounge_scrape_runs")
}
