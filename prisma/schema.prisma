generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MasterCard {
  id               String          @id @default(cuid())
  issuer           String
  cardName         String
  defaultAnnualFee Int
  cardImageUrl     String
  
  // Display properties (NEW)
  displayOrder     Int             @default(0)
  isActive         Boolean         @default(true)
  isArchived       Boolean         @default(false)
  
  // Audit fields (NEW)
  createdByAdminId String?
  archivedByAdminId String?
  archivedAt       DateTime?
  archivedReason   String?
  
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  masterBenefits   MasterBenefit[]
  userCards        UserCard[]

  @@unique([issuer, cardName])
  @@index([issuer])
  @@index([cardName])
  @@index([displayOrder])
  @@index([isActive])
  @@index([isArchived])
}

model MasterBenefit {
  id              String          @id @default(cuid())
  masterCardId    String
  
  name            String
  type            String
  stickerValue    Int
  resetCadence    String
  
  // Default behavior (NEW)
  isDefault       Boolean         @default(true)
  isActive        Boolean         @default(true)
  
  // Audit fields (NEW)
  createdByAdminId String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  masterCard      MasterCard      @relation(fields: [masterCardId], references: [id], onDelete: Cascade)

  @@index([masterCardId])
  @@index([type])
  @@index([resetCadence])
  @@index([isDefault])
  @@index([isActive])
}

model User {
  id             String              @id @default(cuid())
  email          String              @unique
  passwordHash   String
  firstName      String?
  lastName       String?
  emailVerified  Boolean             @default(false)

  // Admin fields (NEW)
  role           UserRole            @default(USER)
  isActive       Boolean             @default(true)

  // Password Reset Fields
  passwordResetToken  String?  @unique @db.VarChar(255)
  passwordResetExpiry DateTime?

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  importJobs     ImportJob[]
  players        Player[]
  sessions       Session[]
  importProfiles UserImportProfile[]
  auditLogs      AdminAuditLog[]     // Admin who performed actions
  
  // Phase 2: Onboarding relationships
  onboardingStates UserOnboardingState[]

  @@index([email])
  @@index([role])
  @@index([isActive])
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expiresAt    DateTime
  isValid      Boolean  @default(true)
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Player {
  id           String        @id @default(cuid())
  userId       String
  playerName   String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  importJobs   ImportJob[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userBenefits UserBenefit[]
  userCards    UserCard[]
  
  // Phase 2: Benefits tracking relationships
  benefitUsageRecords   BenefitUsageRecord[]
  benefitPeriods        BenefitPeriod[]
  recommendations       BenefitRecommendation[]
  onboardingState       UserOnboardingState?

  @@unique([userId, playerName])
  @@index([userId])
}

model UserCard {
  id                  String        @id @default(cuid())
  playerId            String
  masterCardId        String
  customName          String?
  actualAnnualFee     Int?
  renewalDate         DateTime
  isOpen              Boolean       @default(true)
  status              String        @default("ACTIVE")
  statusChangedAt     DateTime?
  statusChangedReason String?
  statusChangedBy     String?
  archivedAt          DateTime?
  archivedBy          String?
  archivedReason      String?
  importedFrom        String?
  importedAt          DateTime?
  version             Int           @default(1)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  userBenefits        UserBenefit[]
  masterCard          MasterCard    @relation(fields: [masterCardId], references: [id])
  player              Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  
  // Phase 2: Benefits tracking relationships
  benefitUsageRecords BenefitUsageRecord[]

  @@unique([playerId, masterCardId])
  @@index([playerId])
  @@index([masterCardId])
  @@index([playerId, masterCardId])
  @@index([playerId, status])
  @@index([renewalDate])
  @@index([archivedAt])
}

model UserBenefit {
  id                String    @id @default(cuid())
  userCardId        String
  playerId          String
  name              String
  type              String
  stickerValue      Int
  resetCadence      String
  userDeclaredValue Int?
  isUsed            Boolean   @default(false)
  timesUsed         Int       @default(0)
  expirationDate    DateTime?
  status            String    @default("ACTIVE")
  importedFrom      String?
  importedAt        DateTime?
  version           Int       @default(1)
  valueHistory      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  claimedAt         DateTime?
  player            Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  userCard          UserCard  @relation(fields: [userCardId], references: [id], onDelete: Cascade)

  @@unique([userCardId, name])
  @@index([userCardId])
  @@index([playerId])
  @@index([userCardId, name])
  @@index([type])
  @@index([isUsed])
  @@index([expirationDate])
}

model ImportJob {
  id                  String         @id @default(cuid())
  playerId            String
  userId              String
  fileName            String
  fileFormat          String
  fileSize            Int
  fileHash            String?
  status              String         @default("Uploaded")
  totalRecords        Int
  processedRecords    Int            @default(0)
  skippedRecords      Int            @default(0)
  failedRecords       Int            @default(0)
  warningRecords      Int            @default(0)
  importType          String
  cardsCreated        Int            @default(0)
  cardsUpdated        Int            @default(0)
  benefitsCreated     Int            @default(0)
  benefitsUpdated     Int            @default(0)
  errorLog            String?
  previewData         String?
  conflictLog         String?
  columnMappings      String?
  detectionConfidence Float?         @default(1.0)
  createdAt           DateTime       @default(now())
  uploadedAt          DateTime?
  parsedAt            DateTime?
  validatedAt         DateTime?
  committedAt         DateTime?
  completedAt         DateTime?
  player              Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  records             ImportRecord[]

  @@index([playerId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([playerId, createdAt])
}

model ImportRecord {
  id                 String    @id @default(cuid())
  importJobId        String
  recordType         String
  rowNumber          Int
  sequenceIndex      Int
  data               String
  normalizedData     String?
  status             String    @default("Valid")
  validationErrors   String?
  validationWarnings String?
  isDuplicate        Boolean   @default(false)
  duplicateOf        String?
  userResolution     String?
  createdCardId      String?
  createdBenefitId   String?
  updatedCardId      String?
  updatedBenefitId   String?
  appliedData        String?
  processedAt        DateTime?
  appliedAt          DateTime?
  importJob          ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@index([status])
  @@index([rowNumber])
  @@index([isDuplicate])
}

model UserImportProfile {
  id                String    @id @default(cuid())
  userId            String
  name              String
  description       String?
  fileFormat        String
  columnMappings    String
  mappingConfidence Float     @default(1.0)
  usageCount        Int       @default(0)
  lastUsedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastUsedAt])
}

// ============================================================================
// ADMIN AUDIT LOGGING - NEW (Phase 1)
// ============================================================================

model AdminAuditLog {
  id              String          @id @default(cuid())
  
  // Who performed the action
  adminUserId     String
  adminUser       User            @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  
  // What was changed
  actionType      AuditActionType // CREATE, UPDATE, DELETE
  resourceType    ResourceType    // CARD, BENEFIT, USER_ROLE, etc.
  resourceId      String
  resourceName    String?
  
  // Change details
  oldValues       String?         // JSON string of previous values
  newValues       String?         // JSON string of new values
  
  // Request context
  ipAddress       String?
  userAgent       String?
  
  // Timestamp
  timestamp       DateTime        @default(now())
  
  @@index([adminUserId])
  @@index([actionType])
  @@index([resourceType])
  @@index([resourceId])
  @@index([timestamp])
  @@index([adminUserId, timestamp])
}

enum AuditActionType {
  CREATE
  UPDATE
  DELETE
}

enum ResourceType {
  CARD
  BENEFIT
  USER_ROLE
  SYSTEM_SETTING
}

// ============================================================================
// PHASE 2: ADVANCED BENEFITS FEATURES
// ============================================================================

// ============================================================================
// BENEFIT USAGE TRACKING - Feature 1
// ============================================================================

model BenefitUsageRecord {
  id              String    @id @default(cuid())
  
  // References
  benefitId       String    // References UserBenefit.id (no FK to allow flexible queries)
  periodId        String
  userCardId      String
  playerId        String
  
  // Usage data
  amount          Int       // In cents for monetary, count for non-monetary
  description     String    @db.Text
  category        String?   // User-provided tag (e.g., "airline fee", "dining")
  usageDate       DateTime  // When the benefit was actually used
  
  // Audit
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  deletedBy       String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  period          BenefitPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  userCard        UserCard  @relation(fields: [userCardId], references: [id], onDelete: Cascade)
  player          Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  
  @@index([benefitId])
  @@index([periodId])
  @@index([playerId])
  @@index([userCardId])
  @@index([usageDate])
  @@index([isDeleted])
  @@index([playerId, usageDate])
}

// ============================================================================
// BENEFIT PERIOD TRACKING - Feature 1 & 2
// ============================================================================

model BenefitPeriod {
  id              String    @id @default(cuid())
  
  // Identity
  benefitId       String    // References UserBenefit.id
  playerId        String
  
  // Period boundaries
  startDate       DateTime
  endDate         DateTime
  resetCadence    String    // MONTHLY, QUARTERLY, ANNUAL, ONETIME
  
  // Aggregated data (cached from BenefitUsageRecord)
  totalAmount     Int       @default(0)  // In cents
  totalCount      Int       @default(0)  // Number of usage events
  lastUsedAt      DateTime?
  
  // Metadata
  periodNumber    Int       // 1-based: which cycle is this? (useful for quarterly/annual)
  isArchived      Boolean   @default(false)
  archivedAt      DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  usageRecords    BenefitUsageRecord[]
  player          Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  
  @@unique([benefitId, playerId, startDate])
  @@index([benefitId])
  @@index([playerId])
  @@index([startDate])
  @@index([resetCadence])
  @@index([isArchived])
}

// ============================================================================
// BENEFIT RECOMMENDATIONS - Feature 4
// ============================================================================

model BenefitRecommendation {
  id              String    @id @default(cuid())
  
  // References
  benefitId       String    // References UserBenefit.id
  playerId        String
  
  // Recommendation content
  title           String
  description     String    @db.Text
  reasoning       String?   @db.Text // Why this recommendation (for display)
  
  // Value & urgency
  potentialValue  Int       // In cents: limit - used
  urgency         String    @default("MEDIUM") // HIGH, MEDIUM, LOW
  priority        Int       @default(0) // For sorting (higher = more important)
  
  // Context
  spendingCategory String?  // Category of spending that triggered this (e.g., "dining")
  spentThisMonth  Int?      // How much user spent in this category
  usedThisMonth   Int?      // How much of benefit used
  remainingLimit  Int?      // How much limit remains
  
  // Tracking
  isDismissed     Boolean   @default(false)
  dismissedAt     DateTime?
  dismissedReason String?
  
  actionTakenAt   DateTime?
  viewCount       Int       @default(0)
  clickCount      Int       @default(0)
  engagementScore Float     @default(0.0)
  
  expiresAt       DateTime? // When this recommendation should no longer show
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  player          Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  
  @@index([benefitId])
  @@index([playerId])
  @@index([urgency])
  @@index([priority])
  @@index([isDismissed])
  @@index([playerId, isDismissed])
  @@index([playerId, createdAt])
}

// ============================================================================
// ONBOARDING STATE - Feature 5
// ============================================================================

model UserOnboardingState {
  id              String    @id @default(cuid())
  
  // References
  playerId        String
  userId          String
  
  // Progress tracking
  step            Int       @default(0) // Current step (0-5 for 6 steps)
  completedSteps  String    @default("") // Comma-separated: "0,2,4"
  skippedStepCount Int      @default(0)
  
  // Reminders
  setupReminders  Boolean   @default(false)
  reminderEmail   String?
  reminderFrequency String? // DAILY, WEEKLY, MONTHLY
  
  // Metadata
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  totalTimeSpent  Int       @default(0) // Seconds
  usedSampleBenefit Boolean @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  player          Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([playerId])
  @@index([userId])
  @@index([completedAt])
}

