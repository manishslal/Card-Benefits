{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm run build",
    "watchPatterns": ["src/**/*", "prisma/**/*", "public/**/*"]
  },
  "deploy": {
    "startCommand": "npm start",
    "releaseCommand": "npx prisma migrate deploy && npx prisma db push --skip-generate",
    "numReplicas": 2,
    "restartPolicyMaxRetries": 5,
    "restartPolicyType": "always",
    "restartPolicyDelay": 30,
    "healthCheck": {
      "enabled": true,
      "endpoint": "/api/health",
      "initialDelaySeconds": 15,
      "periodSeconds": 30,
      "timeoutSeconds": 10,
      "failureThreshold": 5,
      "successThreshold": 2
    },
    "ports": [3000],
    "exposes": [
      {
        "path": "/",
        "port": 3000
      }
    ]
  },
  "plugins": {
    "postgres": {
      "version": "15"
    }
  },
  "variables": {
    "NODE_ENV": "production",
    "LOG_LEVEL": "warn",
    "FEATURE_FLAGS_ENABLED": "phase2b,recommendations,mobile_offline,usage_ui,api_pagination",
    "BENEFIT_ENGINE_ENABLED": "false"
  }
}
